{
  "name": "@linky/linky",
  "version": "0.3.0",
  "description": "Create one short Linky URL that opens a bundle of links.",
  "license": "MIT",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./sdk": {
      "types": "./sdk/client.d.ts",
      "default": "./sdk/client.js"
    }
  },
  "files": [
    "cli/index.js",
    "cli/keys.js",
    "cli/linkies.js",
    "cli/mcp.mjs",
    "cli/sparkline.js",
    "sdk/client.js",
    "sdk/client.d.ts",
    "sdk/index.js",
    "sdk/index.d.ts",
    "skills/linky/SKILL.md",
    "index.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "linky": "cli/index.js",
    "linkie": "cli/index.js"
  },
  "scripts": {
    "dev": "next dev --port 4040",
    "build": "next build",
    "start": "next start --port 4040",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:migrate": "for f in db/migrations/*.sql; do echo \"Applying $f...\"; psql \"$DATABASE_URL\" -f \"$f\" || exit 1; done"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "keywords": [
    "linky",
    "url-shortener",
    "links",
    "agents",
    "cli"
  ],
  "dependencies": {
    "@clerk/nextjs": "^7.2.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.2",
    "svix": "^1.90.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
