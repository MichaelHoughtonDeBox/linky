{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Linky design tokens. Single source of truth for brand color, type, spacing, motion, and elevation. Mirrored to design/tokens.css (CSS custom properties) and src/app/globals.css (runtime). Compatible with the W3C Design Tokens Community Group draft so it imports cleanly into Figma, Style Dictionary, Tokens Studio, and agent tooling.",
  "$extensions": {
    "com.linky": {
      "version": "0.1.0",
      "brand": "Linky",
      "productLine": "launch bundles",
      "updated": "2026-04-18"
    }
  },

  "color": {
    "$description": "Monochrome by design. Any color introduced beyond this palette is a regression — see design/color.md for the rationale.",
    "ink": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Primary foreground. Body text, wordmark, slash mark, primary button fill."
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canonical background. Unchallenged — no gradients, no off-whites."
    },
    "mute": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Secondary text (leads, muted captions, table meta)."
    },
    "line": {
      "$value": "#d9d9d9",
      "$type": "color",
      "$description": "Hairline rule. Borders, dividers, terminal panels."
    },
    "line-strong": {
      "$value": "#111111",
      "$type": "color",
      "$description": "Active focus border. Primary CTA outline. Same ink as text — always square."
    },
    "surface-soft": {
      "$value": "#fafafa",
      "$type": "color",
      "$description": "Faint surface lift for docs tables + zebra blocks. Reach for it sparingly."
    },
    "code-fill": {
      "$value": "#f4f4f4",
      "$type": "color",
      "$description": "Inline-code background, matched to line for 1px borders to read."
    },
    "danger": {
      "$value": "#9a2f24",
      "$type": "color",
      "$description": "Only sanctioned hue beyond monochrome. Use for destructive confirmations and hard errors — never decoration."
    },
    "scrim": {
      "$value": "rgba(17, 17, 17, 0.03)",
      "$type": "color",
      "$description": "Horizontal scanline. Applied via body::before to carry the terminal texture."
    }
  },

  "font": {
    "display": {
      "$value": "Bricolage Grotesque, \"Avenir Next\", sans-serif",
      "$type": "fontFamily",
      "$description": "Display + headline only. Never body."
    },
    "mono": {
      "$value": "IBM Plex Mono, Menlo, Monaco, monospace",
      "$type": "fontFamily",
      "$description": "Default family. Body, UI, terminal blocks, kickers."
    }
  },

  "fontWeight": {
    "regular": { "$value": 400, "$type": "fontWeight" },
    "medium":  { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" }
  },

  "fontSize": {
    "$description": "Expressed in rem for site use. See design/typography.md for px equivalents and slide/keynote recipes.",
    "micro":    { "$value": "0.66rem", "$type": "dimension", "$description": "Code-shell labels, terminal eyebrows." },
    "xs":       { "$value": "0.72rem", "$type": "dimension", "$description": "Terminal label (kickers)." },
    "sm":       { "$value": "0.82rem", "$type": "dimension", "$description": "Docs body, sidebar links, chips." },
    "base":     { "$value": "0.88rem", "$type": "dimension", "$description": "Docs long-form body." },
    "body":     { "$value": "1rem",    "$type": "dimension", "$description": "Default paragraph." },
    "lead":     { "$value": "1.25rem", "$type": "dimension", "$description": "Hero lead, section lede." },
    "h3":       { "$value": "1.35rem", "$type": "dimension" },
    "h2":       { "$value": "1.875rem","$type": "dimension" },
    "h1":       { "$value": "3rem",    "$type": "dimension" },
    "display":  { "$value": "3.75rem", "$type": "dimension", "$description": "Hero H1 on ≥sm. Slides use 5rem+." }
  },

  "letterSpacing": {
    "display":   { "$value": "-0.02em", "$type": "dimension", "$description": "Bricolage display headlines." },
    "lead":      { "$value": "-0.01em", "$type": "dimension" },
    "body":      { "$value": "0",       "$type": "dimension" },
    "kicker":    { "$value": "0.16em",  "$type": "dimension", "$description": "All-caps terminal-label." },
    "chip":      { "$value": "0.05em",  "$type": "dimension" }
  },

  "lineHeight": {
    "tight":   { "$value": 0.9,  "$type": "number", "$description": "Hero H1." },
    "snug":    { "$value": 1.2,  "$type": "number" },
    "normal":  { "$value": 1.44, "$type": "number", "$description": "Terminal code pre." },
    "relaxed": { "$value": 1.62, "$type": "number", "$description": "Docs prose." }
  },

  "space": {
    "$description": "Semantic spacing scale. Section rhythm uses clamp() — see layout.md.",
    "0":  { "$value": "0",       "$type": "dimension" },
    "1":  { "$value": "0.25rem", "$type": "dimension" },
    "2":  { "$value": "0.5rem",  "$type": "dimension" },
    "3":  { "$value": "0.75rem", "$type": "dimension" },
    "4":  { "$value": "1rem",    "$type": "dimension" },
    "5":  { "$value": "1.25rem", "$type": "dimension" },
    "6":  { "$value": "1.5rem",  "$type": "dimension" },
    "8":  { "$value": "2rem",    "$type": "dimension" },
    "10": { "$value": "2.5rem",  "$type": "dimension" },
    "12": { "$value": "3rem",    "$type": "dimension" },
    "16": { "$value": "4rem",    "$type": "dimension" }
  },

  "radius": {
    "$description": "Terminal aesthetic is square. 0 is the default and 99% of surfaces.",
    "square":  { "$value": "0",        "$type": "dimension" },
    "pill":    { "$value": "9999px",   "$type": "dimension", "$description": "Reserved. Do not use without design review." }
  },

  "borderWidth": {
    "hair":    { "$value": "1px", "$type": "dimension" },
    "rule":    { "$value": "2px", "$type": "dimension", "$description": "GitHub header frame. Heavier than hair by one pixel." }
  },

  "shadow": {
    "$description": "Subtle by default. Only elevate on hover or sticky overlay.",
    "none":    { "$value": "none", "$type": "shadow" },
    "focus":   {
      "$value": "0 0 0 1px rgba(17, 17, 17, 0.22), 0 14px 32px rgba(17, 17, 17, 0.12)",
      "$type": "shadow",
      "$description": "Applied to .terminal-input:focus. Two layers: sharp inline ring + long soft lift."
    },
    "cta":     {
      "$value": "0 10px 20px rgba(17, 17, 17, 0.14)",
      "$type": "shadow",
      "$description": "Primary button hover."
    },
    "copy":    {
      "$value": "0 6px 16px rgba(17, 17, 17, 0.08)",
      "$type": "shadow",
      "$description": "Resting copy-to-clipboard chip."
    },
    "shell":   {
      "$value": "0 12px 28px rgba(0, 0, 0, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.04)",
      "$type": "shadow",
      "$description": "Terminal shell surface. Only the app chrome gets this — not cards."
    }
  },

  "motion": {
    "$description": "Every animation is short, cheap, and cued to user action. No loops, no ambient motion.",
    "duration": {
      "instant":    { "$value": "80ms",  "$type": "duration" },
      "fast":       { "$value": "120ms", "$type": "duration", "$description": "Hover + focus transitions." },
      "base":       { "$value": "160ms", "$type": "duration", "$description": "Input focus lift." },
      "entrance":   { "$value": "460ms", "$type": "duration", "$description": "Shell rise on page load." }
    },
    "easing": {
      "standard":   { "$value": "ease",            "$type": "cubicBezier" },
      "out":        { "$value": "ease-out",        "$type": "cubicBezier", "$description": "Entrance animations." },
      "in-out":     { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "spring-ish": { "$value": "cubic-bezier(0.2, 0.9, 0.3, 1)", "$type": "cubicBezier", "$description": "CTA press + copy confirmation." }
    },
    "distance": {
      "lift":   { "$value": "1px",  "$type": "dimension", "$description": "Hover translate-y. Never more than 1px for buttons." },
      "rise":   { "$value": "12px", "$type": "dimension", "$description": "Shell entrance translate-y start." }
    }
  },

  "texture": {
    "scanline": {
      "$description": "Fixed 3px-period horizontal scrim layered via body::before at 0.24 opacity, multiply blend. Keeps the terminal aesthetic present without competing with content.",
      "period": { "$value": "3px", "$type": "dimension" },
      "opacity": { "$value": 0.24, "$type": "number" }
    }
  },

  "breakpoint": {
    "sm":   { "$value": "640px",  "$type": "dimension" },
    "md":   { "$value": "780px",  "$type": "dimension", "$description": "Two-column site grids." },
    "docs": { "$value": "900px",  "$type": "dimension", "$description": "Docs sidebar pins." },
    "lg":   { "$value": "1080px", "$type": "dimension", "$description": "Terminal grid splits." },
    "xl":   { "$value": "1280px", "$type": "dimension" }
  },

  "z": {
    "base":    { "$value": 0,  "$type": "number" },
    "sticky":  { "$value": 10, "$type": "number" },
    "overlay": { "$value": 40, "$type": "number" },
    "toast":   { "$value": 60, "$type": "number" }
  }
}
