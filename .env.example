# ------------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------------

# Postgres connection string (Neon in production, local Postgres in dev).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linky

# Public base URL used in API responses and CLI defaults.
LINKY_BASE_URL=http://localhost:4040

# ------------------------------------------------------------------------------
# Clerk (authentication). Create an application at https://dashboard.clerk.com
# and copy these values from the API keys page.
# ------------------------------------------------------------------------------

# Publishable key is safe to expose to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Secret key is server-only; never expose to the browser.
CLERK_SECRET_KEY=sk_test_...

# Signing secret for Clerk webhooks. Create a webhook in the Clerk dashboard
# pointing at `${LINKY_BASE_URL}/api/webhooks/clerk` and subscribe to all
# `user.*`, `organization.*`, and `organizationMembership.*` events.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Sign-in / sign-up URLs. Must match the catch-all routes in `src/app/signin`
# and `src/app/signup`. Leave these exactly as shown unless you move the routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# ------------------------------------------------------------------------------
# Stripe (billing). Create a Stripe account and copy keys from the Developers
# section. Sprint 1 only uses these to mint customers on user/org creation; no
# paid plans are live yet.
# ------------------------------------------------------------------------------

# Secret key. Use test-mode keys (sk_test_...) in development.
STRIPE_SECRET_KEY=sk_test_...

# Signing secret for Stripe webhooks. Create a webhook endpoint at
# `${LINKY_BASE_URL}/api/webhooks/stripe` and subscribe to subscription events.
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# ------------------------------------------------------------------------------
# Owner-side analytics (Sprint 2.7). Salts the per-day viewer hash written to
# the `launcher_events` table so unique-viewer counts are answerable in
# aggregate without persisting anything re-identifiable (no raw IP, no UA,
# no email, no Clerk id). See `src/lib/server/launcher-events-repository.ts`.
# ------------------------------------------------------------------------------

# 32+ character opaque string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate freely — rotating resets unique-viewer accounting for subsequent days
# while past days stay internally consistent. Leave empty to disable analytics
# writes; the launcher keeps working either way.
LINKY_DAILY_SALT=change-me-to-a-32-plus-char-secret

# ------------------------------------------------------------------------------
# Optional: in-memory API rate limit configuration. Applies to anonymous
# Linky creation (POST /api/links) and launcher events (POST /api/links/:slug/events).
# ------------------------------------------------------------------------------
LINKY_RATE_LIMIT_WINDOW_MS=60000
LINKY_RATE_LIMIT_MAX_REQUESTS=30
